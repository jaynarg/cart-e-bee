# --- Cart E. Bee environment ---
# 1. Copy this file to a new file named  .env.local
# 2. Paste your real Anthropic key after the = sign (no quotes, no spaces)
# 3. Get the key at: https://console.anthropic.com/settings/keys
#
# NEVER commit .env.local to Git. NEVER paste this key into a chat or share it.
# (.env.local is already git-ignored by Next.js.)

ANTHROPIC_API_KEY=sk-ant-paste-your-real-key-here
